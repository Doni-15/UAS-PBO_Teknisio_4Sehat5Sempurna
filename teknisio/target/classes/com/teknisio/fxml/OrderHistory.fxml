<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.OrderHistoryController">

   <!-- Top Header -->
   <top>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="22.0" right="22.0" top="38.0" />
         </padding>
         <children>
            <!-- Header with Back Button -->
            <HBox alignment="CENTER_LEFT" minHeight="54.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn">
                     <graphic>
                        <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                     </graphic>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="section-title" text="Pesanan Saya" style="-fx-font-size: 18px;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Region prefWidth="44.0" />
               </children>
            </HBox>

            <!-- Subtitle -->
            <Label fx:id="txtHistorySubtitle" style="-fx-text-fill: #6B7680; -fx-font-size: 13px;" text="Pantau semua request perbaikan kamu" wrapText="true" />

            <!-- Status Filter Chips (Horizontal Scroll) -->
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" style="-fx-background-color: transparent;" vbarPolicy="NEVER" prefViewportHeight="40.0">
               <content>
                  <HBox fx:id="layoutStatusFilters" alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: transparent;" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </top>

   <!-- Center Scrollable List -->
   <center>
      <VBox spacing="12.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="22.0" right="22.0" top="5.0" />
         </padding>
         <children>
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="layoutOrders" spacing="12.0" style="-fx-background-color: transparent;" />
               </content>
            </ScrollPane>

            <!-- Empty State -->
            <Label fx:id="txtOrderEmpty" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #6B7680; -fx-font-size: 13px; -fx-padding: 16 0;" text="Belum ada order." visible="false" />
         </children>
      </VBox>
   </center>

   <!-- Bottom Refresh Button -->
   <bottom>
      <VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #EBF1F6;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="26.0" left="22.0" right="22.0" top="10.0" />
         </padding>
         <children>
            <Button fx:id="btnRefreshOrders" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="56.0" prefWidth="320.0" styleClass="primary-btn" text="Refresh" />
         </children>
      </VBox>
   </bottom>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #EBF1F6;" styleClass="hide-scrollbars" stylesheets="@../css/style.css" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.ChatDetailController">
   <content>
      <VBox prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;">
         <children>
            
            <!-- Top Header Bar -->
            <VBox style="-fx-background-color: #FFFFFF; -fx-padding: 0 0 8px 0;" styleClass="chat-detail-header">
               <children>
                  <!-- Status Bar Spacing (simulate) -->
                  <Region prefHeight="10.0" />
                  
                  <!-- Header Row: Back, Avatar, Name, Call/Video -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <padding>
                        <Insets left="16.0" right="16.0" top="8.0" />
                     </padding>
                     <children>
                        <!-- Back Button -->
                        <Button mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn">
                           <graphic>
                              <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                           </graphic>
                        </Button>
                        
                        <!-- Contact Avatar -->
                        <StackPane styleClass="chat-detail-avatar-wrapper">
                           <children>
                              <ImageView fx:id="contactAvatar" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="false">
                                 <image>
                                    <Image url="@../assets/technicians/tech_ahmed.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </StackPane>
                        
                        <!-- Contact Name & Status -->
                        <VBox alignment="CENTER_LEFT" spacing="1.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="contactNameLabel" styleClass="chat-detail-name" text="Ahmed Rush" />
                              <Label fx:id="contactStatusLabel" styleClass="chat-detail-status" text="Online" />
                           </children>
                        </VBox>
                        
                        <!-- Call Button -->
                        <Button mnemonicParsing="false" onAction="#handleCall" styleClass="chat-action-btn">
                           <graphic>
                              <SVGPath content="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="#2D4B73" scaleX="0.8" scaleY="0.8" />
                           </graphic>
                        </Button>
                        
                        <!-- Video Call Button -->
                        <Button mnemonicParsing="false" onAction="#handleVideoCall" styleClass="chat-action-btn">
                           <graphic>
                              <SVGPath content="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="#2D4B73" scaleX="0.8" scaleY="0.8" />
                           </graphic>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Date Separator -->
            <HBox alignment="CENTER" style="-fx-padding: 12px 0 4px 0;">
               <children>
                  <Label fx:id="dateLabel" styleClass="chat-date-separator" text="Today" />
               </children>
            </HBox>
            
            <!-- Messages List (Scrollable) -->
            <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #EBF1F6;" styleClass="hide-scrollbars" vbarPolicy="ALWAYS" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="messagesContainer" spacing="8.0" style="-fx-background-color: #EBF1F6;">
                     <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="8.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
            
            <!-- Input Bar -->
            <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E7EC transparent transparent transparent; -fx-border-width: 1px 0 0 0;">
               <padding>
                  <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
               </padding>
               <children>
                  <!-- Attachment Button -->
                  <Button mnemonicParsing="false" onAction="#handleAttach" styleClass="chat-input-action-btn">
                     <graphic>
                        <SVGPath content="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z" fill="#6F7E91" scaleX="0.8" scaleY="0.8" />
                     </graphic>
                  </Button>
                  
                  <!-- Text Input -->
                  <TextField fx:id="messageInput" promptText="Type a message..." styleClass="chat-message-input" HBox.hgrow="ALWAYS" />
                  
                  <!-- Send Button -->
                  <Button fx:id="sendBtn" mnemonicParsing="false" onAction="#handleSend" styleClass="chat-send-btn">
                     <graphic>
                        <SVGPath content="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" fill="#FFFFFF" scaleX="0.9" scaleY="0.9" />
                     </graphic>
                  </Button>
               </children>
            </HBox>
            
         </children>
      </VBox>
   </content>
</ScrollPane>
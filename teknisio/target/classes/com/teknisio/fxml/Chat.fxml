<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #EBF1F6;" styleClass="hide-scrollbars" stylesheets="@../css/style.css" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.ChatController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            
            <!-- Header: Back Button & Title & Search -->
            <VBox spacing="12.0">
               <children>
                  <StackPane prefHeight="50.0">
                     <children>
                        <!-- Back button left aligned -->
                        <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn" StackPane.alignment="CENTER_LEFT">
                           <graphic>
                              <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                           </graphic>
                        </Button>
                        
                        <!-- Centered Title -->
                        <Label styleClass="section-title" style="-fx-font-size: 16px;" text="Messages" StackPane.alignment="CENTER" />
                     </children>
                  </StackPane>
                  
                  <!-- Search Bar -->
                  <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="chat-search-bar">
                     <children>
                        <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#6F7E91" scaleX="0.8" scaleY="0.8" />
                        <TextField fx:id="searchField" promptText="Search conversations..." styleClass="chat-search-input" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Active Chats Section -->
            <VBox spacing="6.0">
               <children>
                  <Label styleClass="chat-section-label" text="Active Conversations" />
                  
                  <!-- Card Section: Chat List -->
                  <VBox fx:id="activeChatContainer" styleClass="chat-card">
                     <!-- Chats will be dynamically added -->
                  </VBox>
               </children>
            </VBox>
            
            <!-- Technician Contacts Section -->
            <VBox spacing="6.0">
               <children>
                  <Label styleClass="chat-section-label" text="Available Technicians" />
                  
                  <!-- Card Section -->
                  <VBox fx:id="technicianChatContainer" styleClass="chat-card">
                     <!-- Chats will be dynamically added -->
                  </VBox>
               </children>
            </VBox>
            
         </children>
      </VBox>
   </content>
</ScrollPane>
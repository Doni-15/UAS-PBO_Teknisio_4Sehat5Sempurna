<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.OrderHistoryController">

   <!-- Top Header -->
   <top>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="22.0" right="22.0" top="38.0" />
         </padding>
         <children>
            <!-- Header with Back Button -->
            <HBox alignment="CENTER_LEFT" minHeight="54.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn">
                     <graphic>
                        <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                     </graphic>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="section-title" text="Pesanan Saya" style="-fx-font-size: 18px;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Region prefWidth="44.0" />
               </children>
            </HBox>

            <!-- Subtitle -->
            <Label fx:id="txtHistorySubtitle" style="-fx-text-fill: #6B7680; -fx-font-size: 13px;" text="Pantau semua request perbaikan kamu" wrapText="true" />

            <!-- Status Filter Chips -->
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" style="-fx-background-color: transparent;" vbarPolicy="NEVER" prefViewportHeight="40.0">
               <content>
                  <HBox fx:id="layoutStatusFilters" alignment="CENTER_LEFT" spacing="8.0" style="-fx-background-color: transparent;" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </top>

   <!-- Center Scrollable List -->
   <center>
      <VBox spacing="12.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="22.0" right="22.0" top="5.0" />
         </padding>
         <children>
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="layoutOrders" spacing="12.0" style="-fx-background-color: transparent;" />
               </content>
            </ScrollPane>

            <Label fx:id="txtOrderEmpty" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #6B7680; -fx-font-size: 13px; -fx-padding: 16 0;" text="Belum ada order." visible="false" />
         </children>
      </VBox>
   </center>

   <!-- Bottom: Navigation Bar + Refresh Button -->
   <bottom>
      <VBox BorderPane.alignment="CENTER" style="-fx-background-color: #EBF1F6;">
         <children>
            <HBox alignment="CENTER" styleClass="bottom-nav-bar">
               <children>
                  <!-- Home -->
                  <HBox alignment="CENTER" onMouseClicked="#handleHomeTab" spacing="6.0" styleClass="nav-item" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                     <children>
                        <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" styleClass="nav-icon" />
                        <Label styleClass="nav-label" text="Home" />
                     </children>
                  </HBox>
                  <!-- History (Active) -->
                  <HBox alignment="CENTER" spacing="6.0" styleClass="nav-item, nav-item-active" HBox.hgrow="ALWAYS">
                     <children>
                        <SVGPath content="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" styleClass="nav-icon" />
                        <Label styleClass="nav-label" text="History" />
                     </children>
                  </HBox>
                  <!-- Account -->
                  <HBox alignment="CENTER" onMouseClicked="#handleAccountTab" spacing="6.0" styleClass="nav-item" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                     <children>
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" styleClass="nav-icon" />
                        <Label styleClass="nav-label" text="Account" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <VBox alignment="CENTER" spacing="12.0">
               <padding>
                  <Insets bottom="20.0" left="22.0" right="22.0" top="8.0" />
               </padding>
               <children>
                  <Button fx:id="btnRefreshOrders" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="48.0" prefWidth="320.0" styleClass="primary-btn" text="Refresh" />
               </children>
            </VBox>
         </children>
      </VBox>
   </bottom>
</BorderPane>
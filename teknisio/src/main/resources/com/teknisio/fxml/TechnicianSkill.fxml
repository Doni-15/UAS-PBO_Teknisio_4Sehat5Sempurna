<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.TechnicianSkillController">

   <!-- Top Header -->
   <top>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="22.0" right="22.0" top="38.0" />
         </padding>
         <children>
            <!-- Header with Back Button -->
            <HBox alignment="CENTER_LEFT" minHeight="54.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn">
                     <graphic>
                        <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                     </graphic>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="section-title" text="Kelola Keahlian" style="-fx-font-size: 18px;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Region prefWidth="44.0" />
               </children>
            </HBox>

            <!-- Subtitle -->
            <Label fx:id="txtSkillSubtitle" style="-fx-text-fill: #6B7680; -fx-font-size: 13px;" text="Atur kategori perangkat yang bisa kamu tangani." wrapText="true" />
         </children>
      </VBox>
   </top>

   <!-- Scrollable Main Content -->
   <center>
      <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" vbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="20.0" style="-fx-background-color: transparent;">
               <padding>
                  <Insets bottom="34.0" left="22.0" right="22.0" top="5.0" />
               </padding>
               <children>

                   <!-- Keahlian Aktif Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Keahlian Aktif" style="-fx-font-size: 18px;" />
                         <VBox fx:id="layoutCurrentSkills" spacing="10.0" styleClass="form-card">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </VBox>
                         <Label fx:id="txtCurrentSkillEmpty" style="-fx-font-size: 12px; -fx-text-fill: #6B7680; -fx-padding: 4 0;" text="Belum ada keahlian aktif." visible="false" />
                      </children>
                   </VBox>

                   <!-- Kategori Tersedia Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Kategori Tersedia" style="-fx-font-size: 18px;" />
                         <VBox fx:id="layoutAvailableSkills" spacing="10.0" styleClass="form-card">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </VBox>
                         <Label fx:id="txtAvailableSkillEmpty" style="-fx-font-size: 12px; -fx-text-fill: #6B7680; -fx-padding: 4 0;" text="Semua kategori sudah menjadi keahlian kamu." visible="false" />
                      </children>
                   </VBox>

                   <!-- Refresh Button -->
                   <Button fx:id="btnRefreshSkills" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="52.0" prefWidth="320.0" styleClass="primary-btn" text="Refresh" />

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>

</BorderPane>
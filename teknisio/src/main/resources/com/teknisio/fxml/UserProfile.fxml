<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.UserProfileController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="18.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            
            <!-- Header: Back Button & Title -->
            <StackPane prefHeight="50.0">
               <children>
                  <!-- Back button left aligned -->
                  <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn" StackPane.alignment="CENTER_LEFT">
                     <graphic>
                        <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                     </graphic>
                  </Button>
                  
                  <!-- Centered Title -->
                  <Label styleClass="section-title" text="Account" style="-fx-font-size: 16px;" StackPane.alignment="CENTER" />
               </children>
            </StackPane>
            
            <!-- Profile Avatar and Status Info -->
            <VBox alignment="CENTER" spacing="8.0">
               <children>
                  <!-- Circular Profile Image Wrapper -->
                  <StackPane fx:id="profileImageWrapper" styleClass="profile-avatar-wrapper">
                     <children>
                        <ImageView fx:id="profileImageView" fitHeight="92.0" fitWidth="92.0" pickOnBounds="true" preserveRatio="false">
                           <image>
                              <Image url="@../assets/profile/profile.png" />
                           </image>
                        </ImageView>
                     </children>
                  </StackPane>
                  
                  <!-- Profile Name -->
                  <Label fx:id="profileNameLabel" styleClass="profile-name" text="Muhammad Farhan Prasetyo" />
                  
                  <!-- Verified Badge Status -->
                  <Label styleClass="verified-badge" text="Verified" />
               </children>
            </VBox>
            
            <!-- Account Information Card Section -->
            <VBox alignment="CENTER_LEFT" spacing="6.0">
               <children>
                  <Label styleClass="profile-section-title" text="Account" />
                  
                  <VBox styleClass="profile-card">
                     <children>
                        <!-- Row 1: Name -->
                        <HBox alignment="CENTER_LEFT" styleClass="profile-card-row">
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="profile-row-label" text="Name" />
                                    <Label fx:id="rowNameVal" styleClass="profile-row-value" text="Muhammad Farhan Prasetyo" />
                                 </children>
                              </VBox>
                              <Button mnemonicParsing="false" onAction="#handleEditName" styleClass="edit-btn">
                                 <graphic>
                                    <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                 </graphic>
                              </Button>
                           </children>
                        </HBox>
                        
                        <!-- Row 2: Email -->
                        <HBox alignment="CENTER_LEFT" styleClass="profile-card-row">
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="profile-row-label" text="Email" />
                                    <Label fx:id="rowEmailVal" styleClass="profile-row-value" text="farhanprasetyo@gmail.com" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <!-- Row 3: Phone Number -->
                        <HBox alignment="CENTER_LEFT" styleClass="profile-card-row-last">
                           <children>
                              <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="profile-row-label" text="Phone Number" />
                                    <Label fx:id="rowPhoneVal" styleClass="profile-row-value" text="+62812 3456 7890" />
                                 </children>
                              </VBox>
                              <Button mnemonicParsing="false" onAction="#handleEditPhone" styleClass="edit-btn">
                                 <graphic>
                                    <SVGPath content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                 </graphic>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <!-- Settings Card Section -->
            <VBox alignment="CENTER_LEFT" spacing="6.0">
               <children>
                  <Label styleClass="profile-section-title" text="Settings" />
                  
                  <VBox styleClass="profile-card">
                     <children>
                        <!-- Language -->
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#handleLanguageClick" spacing="14.0" styleClass="profile-card-row" style="-fx-cursor: hand;">
                           <children>
                              <SVGPath content="M12.87 15.07l-2.54-2.51.03-.03c1.74-1.94 2.98-4.17 3.71-6.53H17V4h-7V2H8v2H1v1.99h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z" styleClass="profile-row-icon" scaleX="0.85" scaleY="0.85" />
                              <Label styleClass="profile-row-text" text="Language" />
                              <Region HBox.hgrow="ALWAYS" />
                              <SVGPath content="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" styleClass="profile-row-icon" opacity="0.6" scaleX="0.8" scaleY="0.8" />
                           </children>
                        </HBox>
                        
                        <!-- Terms & Conditions -->
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#handleTermsClick" spacing="14.0" styleClass="profile-card-row" style="-fx-cursor: hand;">
                           <children>
                              <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" styleClass="profile-row-icon" scaleX="0.85" scaleY="0.85" />
                              <Label styleClass="profile-row-text" text="Terms &amp; Condition" />
                              <Region HBox.hgrow="ALWAYS" />
                              <SVGPath content="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" styleClass="profile-row-icon" opacity="0.6" scaleX="0.8" scaleY="0.8" />
                           </children>
                        </HBox>
                        
                        <!-- Privacy Policy -->
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#handlePrivacyClick" spacing="14.0" styleClass="profile-card-row" style="-fx-cursor: hand;">
                           <children>
                              <SVGPath content="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" styleClass="profile-row-icon" scaleX="0.85" scaleY="0.85" />
                              <Label styleClass="profile-row-text" text="Privacy Policy" />
                              <Region HBox.hgrow="ALWAYS" />
                              <SVGPath content="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" styleClass="profile-row-icon" opacity="0.6" scaleX="0.8" scaleY="0.8" />
                           </children>
                        </HBox>
                        
                        <!-- Call Center -->
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#handleCallCenterClick" spacing="14.0" styleClass="profile-card-row-last" style="-fx-cursor: hand;">
                           <children>
                              <SVGPath content="M12 2c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9zm-5 13v4H6c-.55 0-1-.45-1-1v-3h2zm12 3c0 .55-.45 1-1 1h-1v-4h2v3z" styleClass="profile-row-icon" scaleX="0.85" scaleY="0.85" />
                              <Label styleClass="profile-row-text" text="Call Center" />
                              <Region HBox.hgrow="ALWAYS" />
                              <SVGPath content="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z" styleClass="profile-row-icon" opacity="0.6" scaleX="0.8" scaleY="0.8" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <!-- Spacing region to push logout button down slightly -->
            <Region prefHeight="10.0" />
            
            <!-- Log Out Button -->
            <Button fx:id="logoutBtn" alignment="CENTER" mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-btn">
               <graphic>
                  <HBox alignment="CENTER" spacing="8.0">
                     <children>
                        <SVGPath content="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" styleClass="logout-icon" scaleX="0.95" scaleY="0.95" />
                        <Label style="-fx-text-fill: #E74C3C; -fx-font-weight: bold; -fx-font-size: 13px;" text="Log Out" />
                     </children>
                  </HBox>
               </graphic>
            </Button>
            
         </children>
      </VBox>
   </content>
</ScrollPane>

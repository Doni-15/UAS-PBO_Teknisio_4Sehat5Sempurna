<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.TechnicianRequestDetailController">

   <!-- Top Header -->
   <top>
      <HBox alignment="CENTER_LEFT" minHeight="54.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="22.0" right="22.0" top="38.0" />
         </padding>
         <children>
            <Button mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn">
               <graphic>
                  <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
               </graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="section-title" text="Detail Request" style="-fx-font-size: 18px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Region prefWidth="44.0" />
         </children>
      </HBox>
   </top>

   <!-- Scrollable Main Content -->
   <center>
      <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" vbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="20.0" style="-fx-background-color: transparent;">
               <padding>
                  <Insets bottom="34.0" left="22.0" right="22.0" top="10.0" />
               </padding>
               <children>

                   <!-- Order Info Card -->
                   <VBox spacing="10.0" styleClass="form-card">
                      <padding>
                         <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                      </padding>
                      <children>
                         <Label fx:id="txtTechOrderCode" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2329;" text="REQ-" />
                         <StackPane fx:id="techStatusBadgeContainer" alignment="CENTER_LEFT">
                            <children>
                               <Label fx:id="txtTechOrderStatus" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 5 12;" text="Menunggu" />
                            </children>
                         </StackPane>
                         <Label fx:id="txtTechOrderTime" style="-fx-font-size: 12px; -fx-text-fill: #6B7680;" text="Waktu request" />
                      </children>
                   </VBox>

                   <!-- Pelanggan Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Pelanggan" />
                         <Label fx:id="txtTechCustomer" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73; -fx-line-spacing: 4px;" text="-" wrapText="true">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </Label>
                      </children>
                   </VBox>

                   <!-- Kategori Perangkat Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Kategori Perangkat" />
                         <Label fx:id="txtTechCategories" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73;" text="-" wrapText="true">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </Label>
                      </children>
                   </VBox>

                   <!-- Deskripsi Kerusakan Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Deskripsi Kerusakan" />
                         <Label fx:id="txtTechIssue" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73; -fx-line-spacing: 4px;" text="-" wrapText="true">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </Label>
                      </children>
                   </VBox>

                   <!-- Alamat Servis Section -->
                   <VBox spacing="8.0">
                      <children>
                         <Label styleClass="section-title" text="Alamat Servis" />
                         <Label fx:id="txtTechAddress" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73; -fx-line-spacing: 4px;" text="-" wrapText="true">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </Label>
                      </children>
                   </VBox>

                   <!-- Biaya (Hidden by default) -->
                   <Label fx:id="txtTechCost" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73;" text="Biaya akhir: -" visible="false" wrapText="true">
                      <padding>
                         <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                      </padding>
                   </Label>

                   <!-- Catatan Teknisi (Hidden by default) -->
                   <Label fx:id="txtTechNote" styleClass="form-card" style="-fx-font-size: 13px; -fx-text-fill: #5F6B73; -fx-line-spacing: 4px;" text="-" visible="false" wrapText="true">
                      <padding>
                         <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                      </padding>
                   </Label>

                   <!-- Riwayat Status -->
                   <VBox spacing="8.0">
                      <children>
                         <Label fx:id="txtStatusHistoryLabel" styleClass="section-title" text="Riwayat Status" visible="false" />
                         <VBox fx:id="layoutStatusHistory" spacing="8.0" styleClass="form-card" visible="false">
                            <padding>
                               <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                            </padding>
                         </VBox>
                      </children>
                   </VBox>

                   <!-- Action Panel -->
                   <VBox fx:id="layoutTechnicianActionPanel" spacing="12.0" styleClass="form-card" visible="false">
                      <padding>
                         <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                      </padding>
                      <children>
                         <Label fx:id="txtTechDetailMessage" style="-fx-font-size: 13px; -fx-text-fill: #6B7680;" text="Memuat detail request..." wrapText="true" />

                         <Button fx:id="btnAcceptRequest" mnemonicParsing="false" onAction="#handleAcceptRequest" prefHeight="50.0" prefWidth="290.0" styleClass="primary-btn" text="Terima Request" visible="false" />
                         <Button fx:id="btnStartRequest" mnemonicParsing="false" onAction="#handleStartRequest" prefHeight="50.0" prefWidth="290.0" styleClass="primary-btn" text="Mulai Pengerjaan" visible="false" />
                         <Button fx:id="btnNavigateToCustomer" mnemonicParsing="false" onAction="#handleNavigateToCustomer" prefHeight="50.0" prefWidth="290.0" style="-fx-background-color: #4F70D9; -fx-background-radius: 12px; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="🗺 Navigasi ke Pelanggan" visible="false" />
                         <Button fx:id="btnTechnicianChat" mnemonicParsing="false" onAction="#handleOpenChat" prefHeight="50.0" prefWidth="290.0" styleClass="form-card" style="-fx-text-fill: #2F4A8A; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="💬 Chat Pelanggan" visible="false" />
                         <Button fx:id="btnCompleteRequest" mnemonicParsing="false" onAction="#handleCompleteRequest" prefHeight="50.0" prefWidth="290.0" styleClass="primary-btn" text="Selesaikan Pekerjaan" visible="false" />
                         <Button fx:id="btnRejectRequest" mnemonicParsing="false" onAction="#handleRejectRequest" prefHeight="50.0" prefWidth="290.0" style="-fx-background-color: #FF5A5A; -fx-background-radius: 12px; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="Tolak Request" visible="false" />
                      </children>
                   </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>

</BorderPane>
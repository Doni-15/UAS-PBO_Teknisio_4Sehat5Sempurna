<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="740.0" prefWidth="360.0" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.TechnicianHomeController">

   <!-- Center Scrollable Content -->
   <center>
      <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" vbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="18.0" style="-fx-background-color: transparent;">
               <padding>
                  <Insets bottom="20.0" left="22.0" right="22.0" top="38.0" />
               </padding>
               <children>

                  <!-- Header: Avatar + Name + Notification -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <!-- Avatar -->
                        <StackPane fx:id="technicianAvatarWrapper" styleClass="header-profile-img">
                           <children>
                              <Label fx:id="txtTechnicianAvatar" alignment="CENTER" minHeight="54.0" minWidth="54.0" style="-fx-background-color: #4F70D9; -fx-background-radius: 27px; -fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;" text="T" />
                           </children>
                        </StackPane>

                        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="txtTechnicianGreeting" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2329;" text="Teknisi" />
                              <HBox alignment="CENTER_LEFT" spacing="5.0">
                                 <children>
                                    <SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#2D4B73" scaleX="0.7" scaleY="0.7" />
                                    <Label fx:id="txtTechnicianSubtitle" style="-fx-font-size: 13px; -fx-text-fill: #1F2329;" text="Alamat belum diatur" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <!-- Notification Button -->
                        <Button mnemonicParsing="false" onAction="#handleNotification" styleClass="circle-btn">
                           <graphic>
                              <SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2zm-2 1H8v-6c0-2.48 1.51-4.5 4-4.5s4 2.02 4 4.5v6z" fill="#2D4B73" scaleX="0.8" scaleY="0.8" />
                           </graphic>
                        </Button>
                     </children>
                  </HBox>

                  <!-- Pesanan Kamu Section -->
                  <VBox spacing="8.0">
                     <children>
                        <Label styleClass="section-title" text="Pesanan Kamu" style="-fx-font-size: 20px;" />
                        <Label fx:id="txtTechnicianRequestCount" style="-fx-font-size: 13px; -fx-text-fill: #6B7680;" text="Memuat request..." />

                        <!-- Orders Card -->
                        <VBox fx:id="cardTechnicianOrders" spacing="12.0" styleClass="form-card" minHeight="500.0">
                           <padding>
                              <Insets bottom="16.0" left="14.0" right="14.0" top="16.0" />
                           </padding>
                           <children>
                              <VBox fx:id="layoutTechnicianRequests" spacing="12.0" style="-fx-background-color: transparent;" />
                              <Label fx:id="txtTechnicianEmpty" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 13px; -fx-text-fill: #6B7680; -fx-padding: 20 0;" text="Belum ada request." visible="false" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>

   <!-- Bottom Navigation Bar -->
   <bottom>
      <HBox alignment="CENTER" styleClass="bottom-nav-bar" BorderPane.alignment="CENTER">
         <children>
            <!-- Home -->
            <HBox alignment="CENTER" spacing="6.0" styleClass="nav-item, nav-item-active" HBox.hgrow="ALWAYS">
               <children>
                  <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" styleClass="nav-icon" />
                  <Label styleClass="nav-label" text="Home" />
               </children>
            </HBox>

            <!-- History -->
            <HBox alignment="CENTER" onMouseClicked="#handleHistoryTab" spacing="6.0" styleClass="nav-item" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
               <children>
                  <SVGPath content="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" styleClass="nav-icon" />
                  <Label styleClass="nav-label" text="History" />
               </children>
            </HBox>

            <!-- Skills -->
            <HBox alignment="CENTER" onMouseClicked="#handleSkillTab" spacing="6.0" styleClass="nav-item" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
               <children>
                  <SVGPath content="M19 19H5V5h14v14M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m-1 7h-2V8h2v2m-3 0h-2V8h2v2m-3 0H8V8h2v2m-2 2h8v-2H8v2z" styleClass="nav-icon" />
                  <Label styleClass="nav-label" text="Skills" />
               </children>
            </HBox>

            <!-- Account -->
            <HBox alignment="CENTER" onMouseClicked="#handleAccountTab" spacing="6.0" styleClass="nav-item" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
               <children>
                  <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" styleClass="nav-icon" />
                  <Label styleClass="nav-label" text="Account" />
               </children>
            </HBox>
         </children>
      </HBox>
   </bottom>
</BorderPane>